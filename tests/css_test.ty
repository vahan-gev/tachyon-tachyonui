// TachyonUI engine tests — run with `tachyon test` in lib/tachyonui.
// Headless: no window is created; widgets/rules accumulate across tests,
// so each test uses unique class names.

@test
function colorParsing(): void {
    let c = cssColor("#ff0000");
    assert(c.ok);
    assertEq(c.r, 1.0);
    assertEq(c.g, 0.0);
    assertEq(c.b, 0.0);
    assertEq(c.a, 1.0);

    let short = cssColor("#0f0");
    assert(short.ok);
    assertEq(short.g, 1.0);

    let alpha = cssColor("#00000080");
    assert(alpha.ok);
    assert(alpha.a > 0.49 && alpha.a < 0.52);

    let rgb = cssColor("rgb(255, 0, 255)");
    assert(rgb.ok);
    assertEq(rgb.r, 1.0);
    assertEq(rgb.b, 1.0);

    let rgba = cssColor("rgba(0, 0, 0, 0.25)");
    assert(rgba.ok);
    assertEq(rgba.a, 0.25);

    assert(cssColor("white").ok);
    assert(cssColor("transparent").ok);
    assertEq(cssColor("transparent").a, 0.0);
    assert(!cssColor("notacolor").ok);
    assert(!cssColor("#12345").ok);
}

@test
function lengthParsing(): void {
    assertEq(cssLen("42px"), 42.0);
    assertEq(cssLen(" 7 "), 7.0);
    assertEq(cssLen("auto"), -1.0);
    assert(cssIsPct("50%"));
    assertEq(cssPct("50%"), 50.0);
}

@test
function selectorsAndSpecificity(): void {
    let b = uiButton("x");
    uiAddClass(b, "t3primary");
    uiSetId(b, "t3go");

    cssParse("button { color: #111111; } "
             + ".t3primary { color: #00ff00; } "
             + "#t3go { color: #0000ff; }");
    let st = cssCompute(b, false);
    assertEq(st.fgB, 1.0);      // #id (100) beats .class (10) beats tag (1)
    assertEq(st.fgG, 0.0);

    // later rule wins a specificity tie
    let l = uiLabel("y");
    uiAddClass(l, "t3a");
    uiAddClass(l, "t3b");
    cssParse(".t3a { font-size: 20px; } .t3b { font-size: 30px; }");
    assertEq(cssCompute(l, false).fontSize, 30.0);
}

@test
function hoverRules(): void {
    let b = uiButton("x");
    uiAddClass(b, "t4hov");
    cssParse(".t4hov { background-color: #ff0000; } "
             + ".t4hov:hover { background-color: #00ff00; }");
    assertEq(cssCompute(b, false).bgR, 1.0);
    assertEq(cssCompute(b, false).bgG, 0.0);
    assertEq(cssCompute(b, true).bgG, 1.0);
    assertEq(cssCompute(b, true).bgR, 0.0);
}

@test
function shorthands(): void {
    let x = uiBox();
    uiAddClass(x, "t5pad");
    cssParse(".t5pad { padding: 4px 8px; margin: 1px 2px 3px 4px; "
             + "border: 2px solid #ff0000; }");
    let st = cssCompute(x, false);
    assertEq(st.padT, 4.0);
    assertEq(st.padB, 4.0);
    assertEq(st.padL, 8.0);
    assertEq(st.padR, 8.0);
    assertEq(st.marT, 1.0);
    assertEq(st.marR, 2.0);
    assertEq(st.marB, 3.0);
    assertEq(st.marL, 4.0);
    assertEq(st.borderWidth, 2.0);
    assertEq(st.boR, 1.0);
}

@test
function commentsAndUnknowns(): void {
    let x = uiBox();
    uiAddClass(x, "t6c");
    cssParse("/* comment { width: 999px; } */ .t6c { width: 50px; "
             + "made-up-property: 12; } /* trailing */");
    assertEq(cssCompute(x, false).width, 50.0);
}

@test
function columnLayout(): void {
    let root = uiBox();
    uiSetId(root, "t7root");
    let a = uiBox();
    uiAddClass(a, "t7a");
    let b = uiBox();
    uiAddClass(b, "t7b");
    uiAppend(root, a);
    uiAppend(root, b);
    cssParse("#t7root { padding: 10px; gap: 5px; } "
             + ".t7a { width: 100px; height: 40px; } "
             + ".t7b { height: 60px; }");
    uiSetRoot(root);
    uiComputeStyles();
    uiLayoutRoot(800.0, 600.0);

    assertEq(uiW[root], 800.0);
    assertEq(uiH[root], 600.0);
    assertEq(uiX[a], 10.0);
    assertEq(uiY[a], 10.0);
    assertEq(uiW[a], 100.0);
    assertEq(uiH[a], 40.0);
    assertEq(uiY[b], 55.0);          // 10 + 40 + 5
    assertEq(uiW[b], 780.0);         // auto box stretches (align-items: stretch)
}

@test
function rowJustifyCenter(): void {
    let root = uiBox();
    uiSetId(root, "t8root");
    let a = uiBox();
    uiAddClass(a, "t8i");
    let b = uiBox();
    uiAddClass(b, "t8i");
    uiAppend(root, a);
    uiAppend(root, b);
    cssParse("#t8root { flex-direction: row; justify-content: center; "
             + "align-items: center; gap: 10px; } "
             + ".t8i { width: 50px; height: 20px; }");
    uiSetRoot(root);
    uiComputeStyles();
    uiLayoutRoot(400.0, 100.0);

    // content 400 wide, items 50+10+50=110, leftover 290 → first at 145
    assertEq(uiX[a], 145.0);
    assertEq(uiX[b], 205.0);
    assertEq(uiY[a], 40.0);          // (100-20)/2
}

@test
function hitTestingAndHandlers(): void {
    let root = uiBox();
    uiSetId(root, "t9root");
    let btn = uiButton("hit me");
    uiAddClass(btn, "t9btn");
    uiAppend(root, btn);
    cssParse("#t9root { padding: 20px; } .t9btn { width: 80px; height: 30px; }");
    uiSetRoot(root);
    uiComputeStyles();
    uiLayoutRoot(300.0, 200.0);

    uiMouseX = 25.0;
    uiMouseY = 25.0;
    assertEq(uiHitTest(), btn);
    uiMouseX = 150.0;
    uiMouseY = 150.0;
    assertEq(uiHitTest(), root);

    // click dispatch finds the nearest ancestor handler
    uiOnClick(root, (id: long) => {
        uiSetText(root, "clicked");
    });
    let hi = uiFindHandler(btn);
    assert(hi >= 0L);
    assertEq(uiClickIds[hi], root);
    tuiMouseDown(25.0, 25.0);
    tuiMouseUp(25.0, 25.0);
    assertEq(uiGetText(root), "clicked");
}

@test
function imageElement(): void {
    // 24x16 PNG generated by the test harness
    if (fileExists("/tmp/tachyon_test_img.png")) {
        assertEq(tui_image_width("/tmp/tachyon_test_img.png"), 24.0);
        assertEq(tui_image_height("/tmp/tachyon_test_img.png"), 16.0);
        let img = uiImage("/tmp/tachyon_test_img.png");
        uiSetId(img, "t10img");
        let root = uiBox();
        uiAppend(root, img);
        uiSetRoot(root);
        uiComputeStyles();
        uiLayoutRoot(300.0, 200.0);
        assertEq(uiW[img], 24.0);        // natural size when width/height are auto
        assertEq(uiH[img], 16.0);
    }
    assertEq(tui_image_width("/tmp/no_such_image.png"), 0.0);
}

// ---- v0.2: transforms, opacity, transitions --------------------------------

@test
function transformParsing(): void {
    let b = uiBox();
    uiAddClass(b, "t11tf");
    cssParse(".t11tf { transform: translate(10px, -5px) scale(1.5) rotate(45deg); "
             + "opacity: 0.4; transition: 200ms; }");
    let st = cssCompute(b, false);
    assertEq(st.tx, 10.0);
    assertEq(st.ty, -5.0);
    assertEq(st.scale, 1.5);
    assertEq(st.rotate, 45.0);
    assert(st.opacity > 0.39 && st.opacity < 0.41);
    assertEq(st.transition, 200.0);

    // individual axis functions and 0.3s duration
    let c = uiBox();
    uiAddClass(c, "t11tf2");
    cssParse(".t11tf2 { transform: translateX(20px) translateY(30px); "
             + "transition: transform 0.3s ease; }");
    let s2 = cssCompute(c, false);
    assertEq(s2.tx, 20.0);
    assertEq(s2.ty, 30.0);
    assertEq(s2.transition, 300.0);        // 0.3s -> 300ms
}

@test
function easingSettlesOnTarget(): void {
    // uiEaseToward with f=1 lands exactly on the target; f=0 keeps the source
    let from = TuiStyle();
    let to = TuiStyle();
    to.opacity = 0.0; to.tx = 100.0; to.scale = 2.0; to.bgA = 1.0;
    let mid = uiEaseToward(from, to, 0.5);
    assert(mid.tx > 49.0 && mid.tx < 51.0);   // halfway
    assert(mid.scale > 1.49 && mid.scale < 1.51);
    let done = uiEaseToward(from, to, 1.0);
    assertEq(done.tx, 100.0);
    assertEq(done.scale, 2.0);
    assert(uiSettled(done, to));              // reached the target
    assert(!uiSettled(from, to));             // start is not settled
}

// ---- v0.2: input and checkbox ----------------------------------------------

@test
function inputEditing(): void {
    let inp = uiInput("type here");
    uiFocus(inp);
    assertEq(uiFocused(), inp);
    assertEq(uiValue(inp), "");

    // typing appends at the caret
    tuiTextInput(104);   // 'h'
    tuiTextInput(105);   // 'i'
    assertEq(uiValue(inp), "hi");
    assertEq(uiCaret[inp], 2L);

    // left arrow, then insert in the middle
    tuiKeyDown(37);      // left
    assertEq(uiCaret[inp], 1L);
    tuiTextInput(88);    // 'X' between h and i
    assertEq(uiValue(inp), "hXi");

    // backspace deletes the char before the caret
    tuiKeyDown(8);
    assertEq(uiValue(inp), "hi");

    // enter blurs
    tuiKeyDown(13);
    assertEq(uiFocused(), -1L);

    // typing with nothing focused is ignored
    tuiTextInput(122);
    assertEq(uiValue(inp), "hi");
}

@test
function inputChangeHandler(): void {
    let inp = uiInput("");
    uiFocus(inp);
    let seen = uiBox();                        // a place to record the last value
    uiOnChange(inp, (id: long) => {
        uiSetText(seen, uiValue(id));
    });
    tuiTextInput(97);   // 'a'
    tuiTextInput(98);   // 'b'
    assertEq(uiGetText(seen), "ab");
    uiBlur();
}

@test
function checkboxToggle(): void {
    let root = uiBox();
    uiSetId(root, "t14root");
    let cb = uiCheckbox();
    uiSetId(cb, "t14cb");
    uiAppend(root, cb);
    cssParse("#t14cb { width: 18px; height: 18px; }");
    uiSetRoot(root);
    uiComputeStyles();
    uiLayoutRoot(200.0, 200.0);

    assertEq(uiIsChecked(cb), false);
    let toggles = uiBox();
    uiOnChange(cb, (id: long) => {
        uiSetText(toggles, "changed");
    });
    // click the checkbox: press and release on it
    tuiMouseDown(uiX[cb] + 5.0, uiY[cb] + 5.0);
    tuiMouseUp(uiX[cb] + 5.0, uiY[cb] + 5.0);
    assertEq(uiIsChecked(cb), true);
    assertEq(uiGetText(toggles), "changed");

    // programmatic set
    uiSetChecked(cb, false);
    assertEq(uiIsChecked(cb), false);
}

@test
function inputSizing(): void {
    let inp = uiInput("hi");
    uiSetId(inp, "t15inp");
    let root = uiBox();
    uiAppend(root, inp);
    cssParse("#t15inp { width: 240px; height: 36px; }");
    uiSetRoot(root);
    uiComputeStyles();
    uiLayoutRoot(400.0, 300.0);
    assertEq(uiW[inp], 240.0);
    assertEq(uiH[inp], 36.0);
}

// ---- v0.3: routing, text wrapping, new elements & CSS ----------------------

@test
function newCssProperties(): void {
    let b = uiBox();
    uiAddClass(b, "t16css");
    cssParse(".t16css { text-align: center; line-height: 22px; white-space: nowrap; "
             + "overflow: scroll; display: none; position: absolute; "
             + "top: 10px; left: 20px; z-index: 5; min-width: 50px; max-width: 300px; "
             + "min-height: 40px; max-height: 400px; text-decoration: underline; "
             + "box-shadow: 0 4px 12px; }");
    let st = cssCompute(b, false);
    assertEq(st.textAlign, 1);
    assertEq(st.lineHeight, 22.0);
    assertEq(st.nowrap, true);
    assertEq(st.overflow, 2);
    assertEq(st.display, 0);
    assertEq(st.position, 2);
    assertEq(st.posT, 10.0);
    assertEq(st.posL, 20.0);
    assertEq(st.zIndex, 5);
    assertEq(st.minW, 50.0);
    assertEq(st.maxW, 300.0);
    assertEq(st.underline, true);
    assertEq(st.shadow, true);
}

@test
function textWrapping(): void {
    // explicit newlines always split, regardless of width
    let a = uiWrapLines("one\ntwo\nthree", 1000.0, 14.0, 0, false);
    assertEq(a.len(), 3L);
    assertEq(a[0], "one");
    assertEq(a[2], "three");

    // nowrap collapses to one line per paragraph
    let b = uiWrapLines("a b c d e f g h", 1.0, 14.0, 0, true);
    assertEq(b.len(), 1L);

    // a tiny width forces each word onto its own line
    let c = uiWrapLines("alpha beta gamma", 1.0, 14.0, 0, false);
    assertEq(c.len(), 3L);

    // a wide width keeps it on one line
    let d = uiWrapLines("alpha beta gamma", 10000.0, 14.0, 0, false);
    assertEq(d.len(), 1L);
}

@test
function radioGroups(): void {
    let a = uiRadio("t18color");
    let b = uiRadio("t18color");
    let c = uiRadio("t18size");           // a different group
    uiSelectRadio(a);
    assertEq(uiIsChecked(a), true);
    assertEq(uiIsChecked(b), false);
    assertEq(uiRadioSelected("t18color"), a);

    uiSelectRadio(b);                     // selecting b clears a
    assertEq(uiIsChecked(a), false);
    assertEq(uiIsChecked(b), true);
    assertEq(uiRadioSelected("t18color"), b);

    uiSelectRadio(c);                     // other group is independent
    assertEq(uiIsChecked(b), true);
    assertEq(uiRadioSelected("t18size"), c);
}

@test
function sliderAndProgress(): void {
    let s = uiSlider();
    assertEq(uiSliderValue(s), 0.5);      // default midpoint
    uiSetSliderValue(s, 0.75);
    assertEq(uiSliderValue(s), 0.75);
    uiSetSliderValue(s, 2.0);             // clamped to 1
    assertEq(uiSliderValue(s), 1.0);
    uiSetSliderValue(s, -1.0);            // clamped to 0
    assertEq(uiSliderValue(s), 0.0);

    let p = uiProgress();
    uiSetProgress(p, 0.3);
    assertEq(uiVal[p], 0.3);
}

@test
function textareaEditing(): void {
    let ta = uiTextarea("notes");
    uiFocus(ta);
    tuiTextInput(104); tuiTextInput(105);   // "hi"
    tuiKeyDown(13);                          // Enter inserts a newline (not blur)
    assertEq(uiFocused(), ta);               // still focused
    tuiTextInput(121); tuiTextInput(111);    // "yo"
    assertEq(uiValue(ta), "hi\nyo");
    tuiKeyDown(27);                          // escape blurs
    assertEq(uiFocused(), -1L);
}

@test
function displayNoneAndLayout(): void {
    let root = uiBox(); uiSetId(root, "t20root");
    let a = uiBox(); uiAddClass(a, "t20a");
    let hidden = uiBox(); uiAddClass(hidden, "t20hidden");
    let b = uiBox(); uiAddClass(b, "t20b");
    uiAppend(root, a); uiAppend(root, hidden); uiAppend(root, b);
    cssParse("#t20root { padding: 0px; gap: 0px; } "
             + ".t20a { height: 30px; } .t20hidden { height: 100px; display: none; } "
             + ".t20b { height: 40px; }");
    uiSetRoot(root);
    uiComputeStyles();
    uiLayoutRoot(200.0, 500.0);
    assertEq(uiY[a], 0.0);
    assertEq(uiH[hidden], 0.0);            // hidden takes no space
    assertEq(uiY[b], 30.0);               // b sits directly after a (hidden skipped)
}

@test
function absolutePositioning(): void {
    let root = uiBox(); uiSetId(root, "t21root");
    let abs = uiBox(); uiAddClass(abs, "t21abs");
    uiAppend(root, abs);
    cssParse("#t21root { padding: 0px; } "
             + ".t21abs { position: absolute; top: 15px; left: 25px; "
             + "width: 50px; height: 50px; }");
    uiSetRoot(root);
    uiComputeStyles();
    uiLayoutRoot(300.0, 300.0);
    assertEq(uiX[abs], 25.0);
    assertEq(uiY[abs], 15.0);
}

@test
function minMaxClamping(): void {
    let root = uiBox(); uiSetId(root, "t22root");
    let wide = uiBox(); uiAddClass(wide, "t22wide");
    uiAppend(root, wide);
    cssParse("#t22root { padding: 0px; } "
             + ".t22wide { width: 1000px; max-width: 200px; height: 10px; }");
    uiSetRoot(root);
    uiComputeStyles();
    uiLayoutRoot(800.0, 300.0);
    assertEq(uiW[wide], 200.0);            // clamped by max-width
}

@test
function scrollContentHeight(): void {
    let root = uiBox(); uiSetId(root, "t23root");
    for (i in 0..5) {
        let item = uiBox(); uiAddClass(item, "t23item");
        uiAppend(root, item);
    }
    cssParse("#t23root { height: 100px; overflow: scroll; padding: 0px; gap: 0px; } "
             + ".t23item { height: 50px; }");
    uiSetRoot(root);
    uiComputeStyles();
    uiLayoutRoot(200.0, 100.0);
    assertEq(uiH[root], 100.0);            // box stays the fixed height
    assertEq(uiContentH[root], 250.0);     // 5 * 50 content
    // wheel scrolls, clamped to content - box
    uiMouseX = 50.0; uiMouseY = 50.0;
    tuiWheel(0.0, 1000.0);
    assertEq(uiScrollY[root], 150.0);      // clamped to 250 - 100
    tuiWheel(0.0, -1000.0);
    assertEq(uiScrollY[root], 0.0);        // clamped to 0
}

@test
function routing(): void {
    uiPage("/t24home", () => {
        let b = uiBox(); uiSetId(b, "t24homebox"); return b;
    });
    uiPage("/t24users/:id", () => {
        let b = uiLabel(`user ${uiRouteParam("id")}`); return b;
    });

    uiNavigate("/t24home");
    assertEq(uiCurrentRoute(), "/t24home");
    assertEq(uiIdName[uiRootId], "t24homebox");

    uiNavigate("/t24users/42");
    assertEq(uiCurrentRoute(), "/t24users/42");
    assertEq(uiRouteParam("id"), "42");
    assertEq(uiGetText(uiRootId), "user 42");

    uiBack();                              // returns to home
    assertEq(uiCurrentRoute(), "/t24home");

    assertEq(uiRouteActive("/t24home"), true);
    assertEq(uiRouteActive("/t24users/42"), false);

    // a link navigates when clicked
    uiNavigate("/t24home");
    let link = uiLink("go", "/t24users/7");
    let root = uiBox(); uiSetId(root, "t24linkroot");
    uiAppend(root, link);
    uiSetRoot(root);
    uiComputeStyles();
    uiLayoutRoot(300.0, 200.0);
    tuiMouseDown(uiX[link] + 2.0, uiY[link] + 2.0);
    tuiMouseUp(uiX[link] + 2.0, uiY[link] + 2.0);
    assertEq(uiCurrentRoute(), "/t24users/7");
    assertEq(uiRouteParam("id"), "7");
}
